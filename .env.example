# WENO EHR API Configuration (from API_Documentation_WOL_EHR_01-05-26.pdf)
# Get these from your WENO certification dashboard: cert.wenoexchange.com

# Partner credentials (Step 2 of WOL guide)
WENO_PARTNER_ID=your_partner_id_here
WENO_MD5_PASSWORD=your_md5_password_here

# EZ encryption key for RxLog URL (Step 12)
# Found in your WENO Online account under Manage Account
WENO_EZ_KEY=your_ez_encryption_key_here

# WenoOnlineLocationID for your registered location (Step 3)
# Format: U###:L### (e.g., U123:L202)
# Default is the test location L1255
WENO_LOCATION_ID=L1255

# Environment mode: TEST or LIVE
# TEST: https://test.wenoexchange.com/webapi/wenoonline.asmx
# LIVE: https://online.wenoexchange.com/webapi/wenoonline.asmx
WENO_MODE=TEST

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/hydr801
